FROM public.ecr.aws/lambda/provided:al2023
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
RUN dnf install -y git gcc g++ cmake
RUN git clone https://github.com/lzpel/chijin && sh -c ". $HOME/.cargo/env && make -C chijin test" && cp -rf chijin/target/occt / && rm -rf chijin
ENV OCCT_ROOT=/occt